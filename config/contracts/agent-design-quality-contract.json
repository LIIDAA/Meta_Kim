{
  "schemaVersion": 1,
  "contractId": "agent-design-quality-contract",
  "owner": "Meta_Kim",
  "purpose": "Evaluate whether governance agents can design abstract, professional, bounded, reusable, and verifiable agent specs.",
  "sourceBoundary": {
    "dependencyProjectsMayInform": [
      "content",
      "capability_behavior",
      "professional_standard",
      "task_artifact_shape",
      "judgment_pattern"
    ],
    "dependencyProjectsMustNotInform": [
      "meta_kim_architecture",
      "durable_identity_structure",
      "runtime_graph_shape",
      "database_schema",
      "owner_hierarchy"
    ],
    "architectureDecisionSource": [
      "Meta_Kim product north star",
      "governance agent responsibility boundaries",
      "skill agent script MCP provider separation",
      "LangGraph-compatible state transitions",
      "RunStateStore evidence and replay needs",
      "quantitative acceptance"
    ]
  },
  "dependencyContentEvidence": [
    {
      "sourceId": "wshobson-agents-style",
      "allowedAbsorption": [
        "professional role naming",
        "concise trigger language",
        "tool awareness",
        "domain-specific examples"
      ],
      "forbiddenAbsorption": [
        "repository architecture",
        "runtime-specific file layout",
        "host-specific preambles"
      ]
    },
    {
      "sourceId": "gstack",
      "allowedAbsorption": [
        "product-flow position",
        "upstream/downstream handoff clarity",
        "keeping concrete work in skill/runtime context"
      ],
      "forbiddenAbsorption": [
        "skill catalog architecture",
        "provider packaging architecture",
        "workflow architecture"
      ]
    },
    {
      "sourceId": "gbrain",
      "allowedAbsorption": [
        "scoped memory policy",
        "gap analysis behavior",
        "evaluation readiness",
        "access boundaries"
      ],
      "forbiddenAbsorption": [
        "memory architecture",
        "graph or database architecture",
        "agent hierarchy"
      ]
    }
  ],
  "requiredSpecFields": [
    "name",
    "description",
    "flowPosition",
    "purpose",
    "capabilities",
    "nonCapabilities",
    "loadoutSlots",
    "inputs",
    "outputs",
    "handoff",
    "memoryPolicy",
    "gapPolicy",
    "verificationPolicy",
    "installProjection",
    "identityCleanliness"
  ],
  "scorecardDimensions": [
    {
      "id": "identity_clarity",
      "passCondition": "Name and description make the role trigger clear without reading implementation details."
    },
    {
      "id": "domain_specificity",
      "passCondition": "Capabilities use domain nouns; replacing the name with generic-agent breaks the logic."
    },
    {
      "id": "flow_fit",
      "passCondition": "Agent has a clear product-flow position and handoff direction."
    },
    {
      "id": "tool_least_privilege",
      "passCondition": "Loadout slots are abstract and minimal; concrete commands stay run-scoped."
    },
    {
      "id": "memory_fit",
      "passCondition": "Memory scope and forbidden memory are explicit and bounded."
    },
    {
      "id": "gap_honesty",
      "passCondition": "Agent states what it cannot know or do and routes gaps to GapDecision."
    },
    {
      "id": "handoff_readiness",
      "passCondition": "Inputs, outputs, upstream, and downstream are reviewable without oral explanation."
    },
    {
      "id": "verification_readiness",
      "passCondition": "At least one fixture or replay check can fail the agent design."
    },
    {
      "id": "install_projection_readiness",
      "passCondition": "Runtime projection status is explicit: eligible, needs_probe, or reference_only."
    },
    {
      "id": "identity_cleanliness",
      "passCondition": "No repo path, file list, ticket, today task, deliverable link, or verify step appears in durable identity."
    },
    {
      "id": "dependency_content_boundary",
      "passCondition": "Dependency project references are content/capability evidence only, never architecture adoption."
    }
  ],
  "hardBlockDimensions": [
    "identity_cleanliness",
    "gap_honesty",
    "tool_least_privilege",
    "memory_fit",
    "dependency_content_boundary"
  ],
  "quantitativeAcceptance": {
    "requiredDimensionPassRate": "100%",
    "genericAgentPassCount": 0,
    "taskBoundIdentityPassCount": 0,
    "dependencyArchitectureCopyPassCount": 0,
    "missingVerifierCount": 0,
    "missingHandoffCount": 0,
    "longTermIdentityPollutionCount": 0
  }
}
